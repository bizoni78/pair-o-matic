<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 13+ wymaga runtime permission na powiadomienia -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Prośba o wyłączenie optymalizacji baterii (sideload — bez ograniczeń Google Play) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".PairOMaticApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pairomatic">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Pairomatic">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Odbiorniki akcji powiadomień trybu testu.
             exported=false: uruchamiane wyłącznie przez PendingIntent tej aplikacji. -->
        <!-- Widget na ekran główny: seria dni, dziś/cel i przycisk „Ucz się". -->
        <receiver
            android:name=".widget.LearnWidgetProvider"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/learn_widget_info" />
        </receiver>

        <receiver
            android:name=".notifications.GradeReceiver"
            android:exported="false" />
        <receiver
            android:name=".notifications.DismissReceiver"
            android:exported="false" />

    </application>

</manifest>
